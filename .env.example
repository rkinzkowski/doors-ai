# Doors AI — environment config
# Copy this file to .env and adjust. .env is gitignored; this file is safe to commit.

# Auto-block flagged IPs at the OS firewall (netsh on Windows, iptables on Linux).
# Requires firewall privileges. Keep at 0 for safe/dev use.
DOORS_AUTO_BLOCK_IPS=0

# ---- Future keys ----
# As Doors grows into paid threat-intel or geolocation APIs, put keys here,
# never in the code. Examples:
# IPINFO_TOKEN=
# VIRUSTOTAL_API_KEY=
